NODE_ENV=development
HOST=0.0.0.0
PORT=8080

FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\firebase-service-account.json

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-public-demo-audiobook-bucket
POLLY_TASK_POLL_INTERVAL_MS=2000

MAX_CHAPTER_TEXT_WORDS=3500

# Gemini credentials stay on the backend. Leave blank only when AI is unused.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
AI_EMBEDDING_DIMENSION=768
AI_RATE_LIMIT_PER_MINUTE=10
AI_DAILY_LIMIT=100
AI_PROVIDER_TIMEOUT_MS=12000
AI_RESPONSE_DEADLINE_MS=30000
AI_PROVIDER_MAX_ATTEMPTS=2
AI_PROVIDER_RETRY_BASE_MS=400
AI_CIRCUIT_FAILURE_THRESHOLD=3
AI_CIRCUIT_OPEN_MS=30000
